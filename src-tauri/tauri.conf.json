{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wido",
  "version": "0.1.0",
  "identifier": "io.wonderup.tasks",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3002",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Wido",
        "width": 480,
        "height": 780,
        "minWidth": 380,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
